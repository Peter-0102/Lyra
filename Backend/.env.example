# Server
PORT=3000
HOST=0.0.0.0

# Redis
REDIS_URL=redis://localhost:6379

# Database (PostgreSQL)
DATABASE_URL=postgresql://mispoti:mispoti@localhost:5432/mispoti

# Audio storage
AUDIO_DIR=./data/audio

# File retention
FILE_TTL_HOURS=168

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=10

# CORS origin (comma-separated or * for development)
CORS_ORIGIN=*

# yt-dlp
YTDLP_TIMEOUT_MS=300000

# JWT
JWT_SECRET=change-this-to-a-secure-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
