# Server
PORT=3000
HOST=0.0.0.0

# Redis
REDIS_URL=redis://localhost:6379

# Database
DATABASE_PATH=./data/db.sqlite

# Audio storage
AUDIO_DIR=./data/audio

# File retention
FILE_TTL_HOURS=168

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=120

# CORS origin (comma-separated or * for development)
CORS_ORIGIN=*
